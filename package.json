{
  "name": "moneyme",
  "version": "0.1.0",
  "private": true,
  "description": "MoneyMe — персональний облік фінансів (веб, ПК)",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace web",
    "test": "npm run test --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
